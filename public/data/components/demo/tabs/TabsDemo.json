{
  "filename": "TabsDemo.tsx",
  "content": "import { Tabs, TabsList, TabsPanel, TabsTab } from \"@/components/ui/tabs\";\r\nimport { Home, Layers, User } from \"lucide-react\";\r\n\r\nexport default function TabsDemo() {\r\n  return (\r\n    <Tabs defaultValue=\"overview\" className=\"w-[400px]\">\r\n      <TabsList>\r\n        <TabsTab value=\"overview\">Overview</TabsTab>\r\n        <TabsTab value=\"projects\">Projects</TabsTab>\r\n        <TabsTab value=\"account\">Account</TabsTab>\r\n      </TabsList>\r\n      <TabsPanel value=\"overview\">\r\n        <div className=\"relative flex h-40 items-center justify-center\">\r\n          <Home size={40} className=\"opacity-20\" />\r\n        </div>\r\n      </TabsPanel>\r\n      <TabsPanel value=\"projects\">\r\n        <div className=\"relative flex h-40 items-center justify-center\">\r\n          <Layers size={40} className=\"opacity-20\" />\r\n        </div>\r\n      </TabsPanel>\r\n      <TabsPanel value=\"account\">\r\n        <div className=\"relative flex h-40 items-center justify-center\">\r\n          <User size={40} className=\"opacity-20\" />\r\n        </div>\r\n      </TabsPanel>\r\n    </Tabs>\r\n  );\r\n}\r\n"
}