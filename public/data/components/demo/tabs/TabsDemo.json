{
  "filename": "TabsDemo.tsx",
  "content": "import { Tabs, TabsList, TabsPanel, TabsTab } from \"@/components/ui/tabs\";\nimport { Home, Layers, User } from \"lucide-react\";\n\nexport default function TabsDemo() {\n  return (\n    <Tabs defaultValue=\"overview\" className=\"w-[400px]\">\n      <TabsList>\n        <TabsTab value=\"overview\">Overview</TabsTab>\n        <TabsTab value=\"projects\">Projects</TabsTab>\n        <TabsTab value=\"account\">Account</TabsTab>\n      </TabsList>\n      <TabsPanel value=\"overview\">\n        <div className=\"relative flex h-40 items-center justify-center\">\n          <Home size={40} className=\"opacity-20\" />\n        </div>\n      </TabsPanel>\n      <TabsPanel value=\"projects\">\n        <div className=\"relative flex h-40 items-center justify-center\">\n          <Layers size={40} className=\"opacity-20\" />\n        </div>\n      </TabsPanel>\n      <TabsPanel value=\"account\">\n        <div className=\"relative flex h-40 items-center justify-center\">\n          <User size={40} className=\"opacity-20\" />\n        </div>\n      </TabsPanel>\n    </Tabs>\n  );\n}\n"
}