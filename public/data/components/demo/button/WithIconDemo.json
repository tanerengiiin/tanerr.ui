{
  "filename": "WithIconDemo.tsx",
  "content": "import { Button } from \"@/components/ui/button\";\nimport { Heart, Plus, Search, Bookmark, Mail, Settings } from \"lucide-react\";\n\nexport default function WithIconDemo() {\n  return (\n    <div className=\"flex flex-col gap-4\">\n      {/* Default variant */}\n      <div className=\"flex flex-wrap items-center gap-4\">\n        <Button>\n          <Plus />\n          Add New\n        </Button>\n        <Button tone=\"secondary\">\n          <Mail />\n          Send Email\n        </Button>\n        <Button tone=\"info\">\n          <Search />\n          Search\n        </Button>\n      </div>\n\n      {/* Outline variant */}\n      <div className=\"flex flex-wrap items-center gap-4\">\n        <Button variant=\"outline\" tone=\"primary\">\n          <Heart />\n          Like\n        </Button>\n        <Button variant=\"outline\">\n          <Bookmark />\n          Save\n        </Button>\n        <Button variant=\"outline\" tone=\"info\">\n          <Settings />\n          Settings\n        </Button>\n      </div>\n\n      {/* Ghost variant */}\n      <div className=\"flex flex-wrap items-center gap-4\">\n        <Button variant=\"ghost\" tone=\"primary\">\n          <Plus />\n          Add New\n        </Button>\n        <Button variant=\"ghost\">\n          <Mail />\n          Send Email\n        </Button>\n        <Button variant=\"ghost\" tone=\"info\">\n          <Search />\n          Search\n        </Button>\n      </div>\n    </div>\n  );\n}\n"
}